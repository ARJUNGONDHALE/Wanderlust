<% layout('/layouts/boilerplate') %>

<style>
  #filters {
    display: flex;
    flex-wrap: wrap;
    text-align: center;
  }
  .filter {
    text-align: center;
    margin-right: 2rem;
    margin-bottom: 1rem;
    opacity: 0.7;
  }
  .filter:hover {
    opacity: 1;
    cursor: pointer;
  }
  .filter p {
    font-size: 0.8rem;
  }
  .tax-info {
    display: none;
  }
  .tax-toggle {
    height: 2.8rem;
    padding: 0.5rem;
    border-radius: 8px;
    margin-left: 6rem;
    display: flex;
    align-items: center;
  }

  .favourite-btn-container {
      position: absolute;
      top: 0;
      right: 0;
      border: none;
      border-radius: 50%;
      width: 30px;
      height: 30px;
      margin: 10px;
    }

.favourite-btn {
  background: none;
  border: none;
  cursor: pointer;

}

.fa-heart {
  color: #ff385c;
  font-size: 1.2rem;
}

.fa-heart:hover {
  color: orange;
  transform: scale(1.2);
  transition: 0.3s;
}
</style>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
  <% for (let list of AllListings) { %>
  <a href="/listings/<%= list?.listing?.id %>" class="listing-link">
    <div class="card col Listing-card">
      <img
        src="<%= list?.listing?.image.url %>"
        loading="lazy"
        width="400"
        height="260"
        class="card-img-top"
        alt="<%= list?.listing?.title %>"
      />

      <div class="card-img-overlay"></div>
      <div class="card-body">
        <p class="card-text">
          <b><%= list?.listing?.title %></b>
          <br />
          &#x20B9;<%= list?.listing?.price ? list?.listing?.price.toLocaleString("en-IN") : "N/A"
          %>/night
          <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
        </p>
      </div>
    </div>
  </a>

  <% }%>
</div>
